COMPOSIO_API_KEY=

# OpenAI — natural-language CLI (`bun run ai`)
OPENAI_API_KEY=
# Optional — default gpt-4o-mini
OPENAI_MODEL=
# Optional: Composio user id used when calling connectedAccounts.link (default: candidate)
COMPOSIO_USER_ID=candidate

# Required for proxyExecute — nanoids printed after `bun run connect` (NOT the user id above)
COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=
COMPOSIO_GOOGLECALENDAR_CONNECTED_ACCOUNT_ID=

# Optional fallback (still not a substitute for the toolkit ids above)
COMPOSIO_CONNECTED_ACCOUNT_ID=

# Required for Send Email test — who receives "API Test Email"
GMAIL_RECIPIENT_EMAIL=you@example.com

GMAIL_SELF_EMAIL=

GMAIL_AUTH_CONFIG_ID=
GOOGLECALENDAR_AUTH_CONFIG_ID=
